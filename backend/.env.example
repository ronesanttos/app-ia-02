DJANGO_DEBUG=true
DJANGO_SECRET_KEY=coloque-uma-chave-forte-aqui
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS/CSRF (ajuste conforme seu frontend)
CORS_ALLOW_ALL_ORIGINS=true
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Segurança simples (API Key). Se vazio, não bloqueia (modo dev).
# API_KEY=sua-chave-aqui

# Throttling do DRF
DRF_THROTTLE_ANON=60/min
DRF_THROTTLE_USER=300/min

DJANGO_LOG_LEVEL=INFO

# Celery + Redis
# Host (runserver local): localhost. O serviço `celery` no docker-compose define
# redis://redis:6379/0 por variável de ambiente — não conflita com este .env no PC.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=270
CELERY_BROKER_CONNECTION_TIMEOUT=2.0
CELERY_SOCKET_CONNECT_TIMEOUT=2.0
CELERY_SOCKET_TIMEOUT=5.0
# Worker: reconexão ao Redis (recomendado em dev)
CELERY_BROKER_CONNECTION_RETRY_ON_STARTUP=true
CELERY_BROKER_CONNECTION_RETRY=true
CELERY_BROKER_CONNECTION_MAX_RETRIES=100
