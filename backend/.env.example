# ===== CONFIGURAÇÃO DJANGO =====
# ⚠️ IMPORTANTE: Usar domínio específico no Render!
# Exemplo: DJANGO_ALLOWED_HOSTS=app-ia-01-backend.onrender.com,seu-dominio.com.br
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=coloque-uma-chave-forte-aqui-min-50-caracteres
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,seu-app.onrender.com

# ===== SEGURANÇA =====
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true

# ===== CORS/CSRF (ajuste conforme seu frontend) =====
CORS_ALLOW_ALL_ORIGINS=false
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://seu-frontend.onrender.com
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://seu-frontend.onrender.com

# ===== API KEY (Segurança simples, opcional) =====
# API_KEY=sua-chave-aqui

# ===== THROTTLING DO DRF =====
DRF_THROTTLE_ANON=60/min
DRF_THROTTLE_USER=300/min

# ===== LOGGING =====
DJANGO_LOG_LEVEL=INFO

# ===== DATABASE =====
# Deixe em branco para usar SQLite em dev, ou use PostgreSQL em produção
# Exemplo: postgresql://user:password@localhost/dbname
DATABASE_URL=

# ===== REDIS (Celery + Cache) =====
# Render fornece REDIS_URL automaticamente em produção
# Em local, use: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ===== CELERY TASK CONFIGURATION =====
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=270
CELERY_BROKER_CONNECTION_TIMEOUT=2.0
CELERY_SOCKET_CONNECT_TIMEOUT=2.0
CELERY_SOCKET_TIMEOUT=5.0
CELERY_BROKER_CONNECTION_RETRY_ON_STARTUP=true
CELERY_BROKER_CONNECTION_RETRY=true
CELERY_BROKER_CONNECTION_MAX_RETRIES=100
